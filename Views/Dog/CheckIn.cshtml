
@{
    ViewData["Title"] = "CheckIn";    
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Page - Check in</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="@Url.Content("~/css/admin-theme.css")" />
    <link rel="stylesheet" href="@Url.Content("~/css/styles_input.css")" />

    <style></style>
</head>
<body>
    <div class="grid-container">

        <div class="header bg-teal-600 text-center text-white">
            <h1>Happy Tails Dog Day Care Attendance Manager</h1>
            <h2>Pooch check in</h2>
        </div>

        <div class="content">
            <img src="../images/checkIn.png" alt="Dashboard showing dog daycare tracking system" width="60" height="80">
        </div>


        <div class="menu">
            <ul>             
                <li><a asp-controller="Dashboard" asp-action="Admin">Home</a></li>
                <li><a asp-controller="Dog" asp-action="DogList">View dogs registered</a></li>
                <li><a asp-controller="Report" asp-action="DailyReport">Daily dog report portal</a></li>
                <li><a asp-controller="Dog" asp-action="CheckOut">Pooch check out</a></li>
                <li><a asp-controller="Dog" asp-action="Register">New Client Registration</a></li>
            </ul>
        </div>



        <form action="/action_page.php">
            <h2>Please complete the form to check in dog</h2>
            <label for="namDog">Name of Dog</label>
            <input type="text" id="namDog" name="namDog" placeholder="Name of Dog" ..">

            <label for="checkTime">Check In Time</label>
            <input type="text" id="checkInTim" name="checkInTim" placeholder="checkInTim" ..">


            <label for="fName">First Name of Guardian</label>
            <input type="text" id="fname" name="fname" placeholder="First Name of Guardian. .">

            <label for="fName">Last Name of Guardian</label>
            <input type="text" id="lname" name="lname" placeholder="Last Name of Guardian..">

            <label for="country">Dog Temperament</label>
            <select id="temperament" name="temperament">
                <option value="happy">Happy</option>
                <option value="anxious">Anxious</option>
                <option value="playful">Playful</option>
                <option value="confident">Confident</option>
                <option value="agressive">Agressive</option>
            </select>
            <br />
            <input type="submit" value="Submit">
        </form>
    </div>

    <div class="footer">
        <p>Current time: <span id="current-datetime"></span></p>
        <p>
            <time datetime="2026-03-28T14:41:00-07:00">
            </time>
        </p>
    </div>

    <script>
        function displayCurrentDateTime() {
            const now = new Date();
            // Formats the date and time based on the user's local settings.
            const formattedDateTime = now.toLocaleString();
            document.getElementById('current-datetime').textContent = formattedDateTime;
        }

        // Run the function once immediately, then update every second (1000ms).
        displayCurrentDateTime();
        setInterval(displayCurrentDateTime, 1000);
    </script>
    </div>
</body>
</html>