@{
    ViewData["Title"] = "Dog List";
    
}
<style>
    .menu ul {
        display: flex;
        margin: 0;
        padding: 0;
    }

    .menu li {
        list-style: none;
        padding: 10px 20px;
        margin: 0;
        background-color: #33b5e5;
    }
    .menu {
        margin-top: 0;
        grid-area: menu;
    }

                .menu li:hover {0
                background-color: #0099cc;
            }
</style>
<link rel="stylesheet" href="~/css/admin-tables.css" />

<div class="menu">
    <ul>
        <li><a asp-controller="Dashboard" asp-action="Employee">Home</a></li>
        <li><a asp-controller="Dog" asp-action="CheckIn">Pooch check in</a></li>
        <li><a asp-controller="Report" asp-action="DailyReport">Daily dog report portal</a></li>
        <li><a asp-controller="Dog" asp-action="CheckOut">Pooch check out</a></li>
        <li><a asp-controller="Dog" asp-action="Register">New Client Registration</a></li>
    </ul>
</div>

<div class="dashboard-container">
    <h2>Active Check-Ins</h2>

    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Check In Time</th>
                <th>Play Style</th>
                <th>Special Note</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Max</td>
                <td>8:05 AM</td>
                <td><span class="badge energetic">Energetic</span></td>
                <td>Loves group play. Monitor during feeding.</td>
            </tr>
            <tr>
                <td>Bailey</td>
                <td>8:22 AM</td>
                <td><span class="badge gentle">Gentle</span></td>
                <td>Prefers small groups.</td>
            </tr>
            <tr>
                <td>Charlie</td>
                <td>9:00 AM</td>
                <td><span class="badge independent">Independent</span></td>
                <td>Needs quiet rest breaks.</td>
            </tr>
            <tr>
                <td>Luna</td>
                <td>9:15 AM</td>
                <td><span class="badge energetic">Energetic</span></td>
                <td>High stamina. Monitor water intake.</td>
            </tr>
            <tr>
                <td>Rocky</td>
                <td>9:45 AM</td>
                <td><span class="badge gentle">Gentle</span></td>
                <td>Friendly with new dogs.</td>
            </tr>
            <tr>
                <td>Daisy</td>
                <td>10:10 AM</td>
                <td><span class="badge independent">Independent</span></td>
                <td>Requires medication at 1 PM.</td>
            </tr>
        </tbody>
    </table>
</div>