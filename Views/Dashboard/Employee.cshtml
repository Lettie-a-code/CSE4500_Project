
@{
    ViewData["Title"] = "Employee";
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Page - Happy Tails</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="@Url.Content("~/css/tech-theme.css")" />
    <link rel="stylesheet" href="@Url.Content("~/css/styles1.css")" />
    <style>
    </style>
</head>
<body>
    <div class="grid-container">

        <div class="header bg-teal-600 text-center text-white">
            <h1>Happy Tails Dog Day Care Attendance Manager</h1>
            <h2>Navigation Page (technician view)</h2>
        </div>
        <!--👉Don’t nest based on “what looks grouped-->
        <!--👉 Nest based on layout role and meaning-->

        <div class="menu">
            <ul>
                <li><a href="/Dog/CheckIn">Pooch check in</a></li>
                <li><a href="/Dog/DogList">View dogs registered</a></li>
                <li><a href="/Report/DailyReport">Daily dog report portal</a></li>
                <li><a href="/Dog/CheckOut">Pooch check out</a></li>
                <li><a href="/Dog/Register">New Client Registration</a></li>
            </ul>
        </div>
        <div class="content">
            <h2>You care for the dogs—we’ll track everything else:</h2>
            <img src="~/images/homePage.png" alt="Dashboard showing dog daycare tracking system" width="125" height="150">
        </div>

        <div class="facts">
            <h1>Schedule</h1>
            <ul>
                <li>Morning walk: 8:00 AM</li>
                <li>Feeding time: 12:00 PM</li>
                <li>Afternoon walk: 4:00 PM</li>
                <li>Evening walk: 8:00 PM</li>
            </ul>
        </div>

        <div class="footer">
            <p>Current time: <span id="current-datetime"></span></p>
            <p>
                <time datetime="2026-03-28T14:41:00-07:00">
                </time>
            </p>
        </div>

        <script>
            function displayCurrentDateTime() {
                const now = new Date();
                // Formats the date and time based on the user's local settings.
                const formattedDateTime = now.toLocaleString();
                document.getElementById('current-datetime').textContent = formattedDateTime;
            }

            // Run the function once immediately, then update every second (1000ms).
            displayCurrentDateTime();
            setInterval(displayCurrentDateTime, 1000);
        </script>
    </div>
</body>
</html>


